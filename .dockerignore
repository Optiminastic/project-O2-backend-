*.py[cod]
.env
.env.*
*.db
*.sqlite3
uploads/
.git/
.gitignore
.github/
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage*
*.log
.DS_Store
Thumbs.db
