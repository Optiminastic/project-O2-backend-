# ─────────────────────────────────────────────────────────────────────────────
# project-O2-backend PRODUCTION env (Hetzner VPS + Docker Compose).
# Copy to `.env` on the server and fill in real values. NEVER commit the real
# .env — only this placeholder template is tracked.
# ─────────────────────────────────────────────────────────────────────────────

# Postgres runs on the VPS (the `db` compose service). Use the SAME password in
# POSTGRES_PASSWORD and inside DATABASE_URL.
POSTGRES_PASSWORD=change-me-to-a-strong-password
# Use the UNIQUE container name project-o2-db as the host (not `db`): this API also
# joins the shared proxy network where another stack's Postgres is aliased `db`,
# so `@db:5432` would resolve to the wrong database.
DATABASE_URL=postgresql+psycopg://o2_admin:change-me-to-a-strong-password@project-o2-db:5432/projecto2

# The Docker network avora's Caddy is on (so it can reach project-o2-api by name).
# Verify with:  docker inspect deploy-caddy-1 -f '{{range $k,$_ := .NetworkSettings.Networks}}{{println $k}}{{end}}'
PROXY_NETWORK=deploy_avora

# Auth — JWT signing key. Generate once and keep stable (rotating it logs everyone out).
SECRET_KEY=change-me-generate-a-random-64-char-hex
ACCESS_TOKEN_EXPIRE_MINUTES=720
ALGORITHM=HS256

# The browser origin of the O2 frontend (Vercel / custom domain). Used for CORS.
FRONTEND_ORIGIN=https://o2.optiminastic.com

# Only emails on this domain may sign up or be invited (the workspace).
WORKSPACE_EMAIL_DOMAIN=optiminastic.com

# Local uploads dir (used when S3 is not configured; mapped to the o2_uploads volume).
UPLOAD_DIR=/app/uploads

# ── Object storage (Amazon S3). Set AWS_S3_BUCKET to route uploads to S3 under
#    AWS_S3_PREFIX (downloads served via presigned URLs). Leave AWS_S3_BUCKET blank
#    to keep uploads on the local volume. Credentials need s3:PutObject/GetObject/
#    DeleteObject on <bucket>/<prefix>* and s3:ListBucket scoped to that prefix. ──
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
AWS_S3_BUCKET=
AWS_S3_PREFIX=o2/

# ── Email: team invitations. Leave SMTP_HOST blank to disable sending (the UI then
#    shows a copy-able invite link instead). For Gmail use an App Password. ──
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=Project O2
SMTP_REPLY_TO=
SMTP_USE_TLS=true
INVITE_EXPIRE_HOURS=168
